{
  "name": "video-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Video downloader with yt-dlp",
  "license": "ISC",
  "author": "Jari Leminaho",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:web": "next dev",
    "dev:build": "node scripts/watch-electron.mjs",
    "dev:electron": "wait-on http://localhost:3000 && nodemon --watch dist-electron --ext js --exec electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:build\" \"npm:dev:electron\"",
    "build:web": "next build",
    "build:electron": "node scripts/build-electron.mjs",
    "start": "next start",
    "lint": "eslint",
    "build": "npm run build:web && npm run build:electron",
    "dist": "electron-builder",
    "dist:dev": "electron-builder --publish never"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-serve": "^3.0.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.14.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.example.video-downloader",
    "productName": "Video tool",
    "directories": {
      "buildResources": "resources"
    },
    "extraResources": [
      {
        "from": "resources/binaries",
        "to": "binaries",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist-electron/**/*",
      "node_modules/**/*",
      "out/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}.exe"
    }
  }
}
